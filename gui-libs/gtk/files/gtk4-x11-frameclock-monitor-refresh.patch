+void
+_gdk_frame_clock_idle_set_surface (GdkFrameClock *clock,
+                                   GdkSurface    *surface)
+{
+  if (!GDK_IS_FRAME_CLOCK_IDLE (clock))
+    return;
+
+  GDK_FRAME_CLOCK_IDLE (clock)->priv->surface = surface;
+}
