+                   * on X11). Use the surface's monitor refresh rate instead
+                   * of the 60Hz FRAME_INTERVAL default. */
+                  gint64 mon_interval = gdk_frame_clock_idle_monitor_interval (clock_idle);
+                  if (mon_interval != 0)
