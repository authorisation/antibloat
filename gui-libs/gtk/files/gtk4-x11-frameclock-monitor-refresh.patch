 G_DEFINE_TYPE_WITH_PRIVATE (GdkFrameClockIdle, gdk_frame_clock_idle, GDK_TYPE_FRAME_CLOCK)

+/* Downstream (antibloat): when no compositor supplies frame timings on X11
+ * (picom / standalone WM => prev_timings->refresh_interval stays 0), derive
+ * the frame interval from the owning surface's monitor refresh rate instead
+ * of the hardcoded 60Hz FRAME_INTERVAL. Returns an interval in microseconds,
+ * or 0 if not applicable (no surface, not X11, invalid monitor). Clamped to
+ * [30,1000] Hz to bound CPU and guard against a misreported refresh rate. */
+static gint64
+gdk_frame_clock_idle_monitor_interval (GdkFrameClockIdle *clock_idle)
+{
+  GdkSurface *surface = clock_idle->priv->surface;
+  GdkDisplay *display;
+  GdkMonitor *monitor;
+  int rate_mhz;
+
+  if (surface == NULL)
+    return 0;
+
+  display = gdk_surface_get_display (surface);
+  if (display == NULL)
+    return 0;
+
+#ifdef GDK_WINDOWING_X11
+  if (!GDK_IS_X11_DISPLAY (display))
+    return 0;
+#else
+  return 0;
+#endif
+
+  monitor = gdk_display_get_monitor_at_surface (display, surface);
+  if (monitor == NULL || !gdk_monitor_is_valid (monitor))
+    return 0;
+
+  rate_mhz = gdk_monitor_get_refresh_rate (monitor); /* millihertz */
+  if (rate_mhz < 30000)
+    rate_mhz = 30000;       /* clamp to >= 30 Hz */
+  if (rate_mhz > 1000000)
+    rate_mhz = 1000000;     /* clamp to <= 1000 Hz */
+
+  return G_GINT64_CONSTANT (1000000000) / rate_mhz; /* microseconds */
+}
+
 static gint64 sleep_serial;
 static gint64 sleep_source_prepare_time;
 static GSource *sleep_source;
